---
import PitchCard from './PitchCard.astro';
import type { Local } from '../../data/mockPitches';

interface Props {
  locales: Local[];
}

const { locales } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  {locales.map((local) => (
    <PitchCard local={local} />
  ))}
</div>