---
import type { Local } from '../../data/mockPitches';

interface Props {
  local: Local;
}

const { local } = Astro.props;
const cantidadCampos = local.campos.length;

// Preparamos los datos EXACTOS para que el buscador los pueda leer
const nombreData = local.nombre; // Pasamos el nombre tal cual, el script lo limpiará
const distritoData = local.distrito.toLowerCase().replace(/ /g, '-').normalize("NFD").replace(/[\u0300-\u036f]/g, "");
const tiposData = local.campos.map(c => c.tipo.replace(/ /g, '').toLowerCase()).join(',');
---

<a 
  href={`/canchas/${local.id}`} 
  class="block group cancha-card" 
  data-nombre={nombreData}
  data-distrito={distritoData} 
  data-tipo={tiposData}
>
  <article class="bg-slate-800/40 border border-slate-700/50 rounded-2xl overflow-hidden hover:shadow-xl hover:shadow-sep-green/5 hover:border-sep-green/30 transition-all duration-300 hover:-translate-y-1 backdrop-blur-sm">
    
    <div class="relative w-full h-48 overflow-hidden bg-slate-900">
      <img 
        src={local.imagenes[0]} 
        alt={`Imagen de ${local.nombre}`} 
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
      <div class="absolute top-3 left-3 bg-slate-950/80 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-semibold text-slate-300 border border-slate-800/80">
        {cantidadCampos} {cantidadCampos === 1 ? 'campo' : 'campos'}
      </div>
    </div>

    <div class="p-5">
      <div class="flex justify-between items-start gap-2">
        <h3 class="text-lg font-bold text-white group-hover:text-sep-green transition-colors leading-tight line-clamp-2">
          {local.nombre}
        </h3>
      </div>

      <div class="flex items-center gap-1 mt-2 text-sm text-slate-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-sep-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span>{local.distrito}</span>
      </div>

      <hr class="my-4 border-slate-700/40" />

      <div class="flex justify-between items-center">
        <div class="flex items-center text-amber-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          <span class="ml-1 text-sm font-medium text-slate-300">{local.calificacion}</span>
        </div>

        <div class="text-right">
          <span class="text-xs text-slate-400 block">Desde</span>
          <span class="text-lg font-bold text-sep-green">S/ {local.precioDesde.toFixed(2)}</span>
        </div>
      </div>

    </div>
  </article>
</a>