---
import '../../styles/global.css';
import { localesMock } from '../../data/mockPitches';
import WhatsAppCTA from '../../components/pitch/WhatsAppCTA.astro';

// Astro requiere esta función para generar los enlaces dinámicos sin dar error
export function getStaticPaths() {
  return localesMock.map(local => ({
    params: { id: local.id },
    props: { local },
  }));
}

const { local } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{local.nombre} - SeparaYA</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  </head>
  <body class="bg-slate-900 min-h-screen font-['Outfit'] text-slate-100 antialiased pb-24"> 
    
    <!-- Header minimalista -->
    <header class="bg-slate-900/80 backdrop-blur-md sticky top-0 z-20 border-b border-slate-800/80 px-4 py-4">
      <div class="max-w-3xl mx-auto">
        <a href="/" class="text-sep-green font-bold flex items-center gap-2 hover:text-[#326955] transition-colors">
          <!-- Icono de flecha -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
          </svg>
          Volver al inicio
        </a>
      </div>
    </header>

    <main class="max-w-3xl mx-auto px-4 py-6">
      
      <!-- Foto Principal -->
      <img src={local.imagenes[0]} alt={local.nombre} class="w-full h-64 md:h-96 object-cover rounded-2xl shadow-md mb-6" />

      <!-- Título y Ubicación -->
      <div class="mb-8">
        <h1 class="text-3xl font-black text-white mb-2 leading-tight">{local.nombre}</h1>
        <p class="text-slate-400 font-medium flex items-center gap-1">
          📍 {local.direccion}, {local.distrito}
        </p>
      </div>

      <!-- Servicios Generales -->
      <section class="bg-slate-800/40 p-6 rounded-2xl shadow-sm mb-6 border border-slate-700/50 backdrop-blur-sm">
        <h2 class="text-xl font-bold text-white mb-4">Servicios Generales</h2>
        <div class="flex flex-wrap gap-2">
          {local.servicios.map(servicio => (
            <span class="bg-sep-green/10 text-sep-green px-3 py-1 rounded-full text-sm font-semibold capitalize border border-sep-green/20">
              {servicio.replace('_', ' ')}
            </span>
          ))}
        </div>
      </section>

      <!-- Lista de Campos Informacionales -->
      <section class="bg-slate-800/40 p-6 rounded-2xl shadow-sm border border-slate-700/50 backdrop-blur-sm">
        <h2 class="text-xl font-bold text-white mb-4">Campos del Local</h2>
        <div class="space-y-4">
          {local.campos.map(campo => (
            <div class="flex justify-between items-center border-b border-slate-700/30 pb-4 last:border-0 last:pb-0">
              <div>
                <h3 class="font-bold text-white text-lg">{campo.nombre}</h3>
                <p class="text-sm text-slate-400">{campo.tipo} • Superficie: {campo.superficie}</p>
              </div>
              <div class="text-right">
                <span class="block text-xs text-slate-500 font-medium uppercase tracking-wider">Hora</span>
                <span class="font-black text-sep-green text-lg">S/ {campo.precioHora.toFixed(2)}</span>
              </div>
            </div>
          ))}
        </div>
      </section>

    </main>

    <!-- El botón de redirección de WhatsApp -->
    <WhatsAppCTA telefono={local.whatsapp} nombreLocal={local.nombre} />

  </body>
</html>