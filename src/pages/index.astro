---
import '../styles/global.css';
import PitchGrid from '../components/pitch/PitchGrid.astro';
import { localesMock } from '../data/mockPitches';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>SeparaYA 📍 | Encuentra y reserva tu cancha</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <meta property="og:title" content="SeparaYA 📍 | Reserva tu cancha hoy" />
    <meta property="og:description" content="Encuentra las mejores canchas en Trujillo y distritos. Consulta disponibilidad directo por WhatsApp y asegura tu pichanga." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://separaya.vercel.app/" />
    <meta property="og:image" content="https://separaya.vercel.app/images/og-separaya.jpg" />
  </head>
  
  <body class="bg-slate-900 min-h-screen font-['Outfit'] text-gray-800 antialiased">
    
    <header class="bg-white shadow-sm sticky top-0 z-10 border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
        <h1 class="text-2xl font-black text-sep-green tracking-tighter">SeparaYA.</h1>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 py-8">
      
      <section class="bg-sep-green rounded-3xl p-8 md:p-12 text-center text-white mb-10 shadow-lg">
        <h2 class="text-4xl md:text-6xl font-extrabold mb-4 tracking-tight">Encuentra dónde jugar hoy</h2>
        <p class="text-white/90 mb-8 max-w-2xl mx-auto text-lg md:text-xl font-medium">
          Explora y reserva en las mejores canchas en Trujillo y distritos.
        </p>

        <div class="flex flex-col items-center gap-4 w-full max-w-2xl mx-auto mt-6">
          
          <!-- BÚSQUEDA PRINCIPAL (Grande y protagonista) -->
          <div class="relative w-full max-w-md z-10">
            <input 
              id="filtro-texto" 
              type="text" 
              placeholder="Escribe el nombre de la cancha" 
              class="w-full bg-white text-gray-800 rounded-2xl md:rounded-full px-6 py-4 pr-14 outline-none shadow-lg font-medium placeholder-gray-400 focus:ring-4 focus:ring-white/30 transition-all text-base md:text-lg"
            >
            <button 
              id="btn-lupa"
              aria-label="Buscar"
              class="absolute right-2 top-1/2 -translate-y-1/2 p-2.5 text-sep-green hover:text-[#326955] hover:bg-green-50 rounded-full transition-all duration-200 active:scale-95 focus:outline-none"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6 hover:scale-110 transition-transform duration-200">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
              </svg>
            </button>
          </div>

          <!-- FILTROS SECUNDARIOS (Estilo Redbus: con iconos y tamaño menor en celular) -->
          <div class="flex flex-col md:flex-row w-full max-w-lg gap-3">
            
            <!-- Selector de Distrito -->
            <div class="relative w-full flex-1">
              <!-- Icono Izquierdo (Pin de ubicación) -->
              <div class="absolute left-4 top-1/2 -translate-y-1/2 text-sep-green pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
              </div>
              
              <!-- El Select (más pequeño en celular: py-3 y text-sm) -->
              <select id="filtro-distrito" class="w-full bg-white text-gray-800 rounded-xl md:rounded-full pl-11 pr-10 py-3 md:py-3.5 outline-none shadow-md font-medium focus:ring-4 focus:ring-white/30 transition-all cursor-pointer text-sm md:text-base appearance-none">
                <option value="">¿En qué distrito?</option>
                <option value="trujillo">Trujillo Centro</option>
                <option value="la-esperanza">La Esperanza</option>
                <option value="el-porvenir">El Porvenir</option>
                <option value="victor-larco">Víctor Larco Herrera</option>
                <option value="huanchaco">Huanchaco</option>
                <option value="florencia-de-mora">Florencia de Mora</option>
                <option value="laredo">Laredo</option>
                <option value="moche">Moche</option>
                <option value="salaverry">Salaverry</option>
                <option value="poroto">Poroto</option>
                <option value="simbal">Simbal</option>
                <option value="alto-trujillo">Alto Trujillo</option>
              </select>

              <!-- Flechita Derecha (Chevron) -->
              <div class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
              </div>
            </div>
            
            <!-- Selector de Tipo de Cancha -->
            <div class="relative w-full flex-1">
              <!-- Icono Izquierdo (Etiqueta/Filtro) -->
              <div class="absolute left-4 top-1/2 -translate-y-1/2 text-sep-green pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z" />
                </svg>
              </div>

              <!-- El Select -->
              <select id="filtro-tipo" class="w-full bg-white text-gray-800 rounded-xl md:rounded-full pl-11 pr-10 py-3 md:py-3.5 outline-none shadow-md font-medium focus:ring-4 focus:ring-white/30 transition-all cursor-pointer text-sm md:text-base appearance-none">
                <option value="">Cualquier tamaño</option>
                <option value="5vs5">Fútbol 5</option>
                <option value="7vs7">Fútbol 7</option>
              </select>

              <!-- Flechita Derecha (Chevron) -->
              <div class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
              </div>
            </div>
            
          </div>
        </div>
      </section>

      <section>
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-2xl font-bold text-white tracking-tight">Canchas Populares</h3>
          <span class="text-sm font-semibold text-slate-300 bg-slate-800 px-4 py-1.5 rounded-full border border-slate-700 shadow-inner" id="contador-resultados">
            {localesMock.length} resultados
          </span>
        </div>
        <PitchGrid locales={localesMock} />
      </section>

    </main>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const inputTexto = document.getElementById('filtro-texto') as HTMLInputElement;
        const btnLupa = document.getElementById('btn-lupa') as HTMLButtonElement;
        const selectDistrito = document.getElementById('filtro-distrito') as HTMLSelectElement;
        const selectTipo = document.getElementById('filtro-tipo') as HTMLSelectElement;
        const tarjetas = document.querySelectorAll('.cancha-card');
        const contadorResultados = document.getElementById('contador-resultados');

        const normalizar = (texto: string) => {
          return texto.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();
        };

        const ejecutarFiltro = () => {
          const textoBuscado = normalizar(inputTexto.value);
          const distritoBuscado = selectDistrito.value.toLowerCase();
          const tipoBuscado = selectTipo.value.toLowerCase();
          
          let canchasVisibles = 0;

          tarjetas.forEach((tarjeta) => {
            const htmlTarjeta = tarjeta as HTMLElement;
            
            const nombreTarjeta = normalizar(htmlTarjeta.getAttribute('data-nombre') || '');
            const distritoTarjeta = htmlTarjeta.getAttribute('data-distrito') || '';
            const tiposTarjeta = htmlTarjeta.getAttribute('data-tipo') || '';

            const coincideTexto = textoBuscado === '' || nombreTarjeta.includes(textoBuscado);
            const coincideDistrito = distritoBuscado === '' || distritoTarjeta.includes(distritoBuscado);
            const coincideTipo = tipoBuscado === '' || tiposTarjeta.includes(tipoBuscado);

            if (coincideTexto && coincideDistrito && coincideTipo) {
              htmlTarjeta.style.display = 'block';
              canchasVisibles++;
            } else {
              htmlTarjeta.style.display = 'none';
            }
          });

          if (contadorResultados) {
            contadorResultados.textContent = `${canchasVisibles} resultado${canchasVisibles !== 1 ? 's' : ''}`;
          }
        };

        inputTexto.addEventListener('keypress', (e) => {
          if (e.key === 'Enter') {
            ejecutarFiltro();
            inputTexto.blur();
          }
        });

        selectDistrito.addEventListener('change', ejecutarFiltro);
        selectTipo.addEventListener('change', ejecutarFiltro);

        if (btnLupa) {
          btnLupa.addEventListener('click', () => {
            ejecutarFiltro();
            inputTexto.blur();
          });
        }
      });
    </script>
  </body>
</html>