---
import '../styles/global.css';
import PitchGrid from '../components/pitch/PitchGrid.astro';
import { localesMock } from '../data/mockPitches';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>SeparaYA 📍 | Encuentra y reserva tu cancha</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <meta property="og:title" content="SeparaYA 📍 | Reserva tu cancha hoy" />
    <meta property="og:description" content="Encuentra las mejores canchas en Trujillo y distritos. Consulta disponibilidad directo por WhatsApp y asegura tu pichanga." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://separaya.vercel.app/" />
    <meta property="og:image" content="https://separaya.vercel.app/images/og-separaya.jpg" />
  </head>
  
  <body class="bg-slate-900 min-h-screen font-['Outfit'] text-gray-800 antialiased">
    
    <header class="bg-white/80 backdrop-blur-md sticky top-0 z-20 border-b border-slate-200/80 text-slate-900">
      <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
        <h1 class="text-2xl font-black text-sep-green tracking-tighter">SeparaYA.</h1>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 py-8">
      
      <section class="bg-sep-green rounded-3xl p-8 md:p-12 text-center text-white mb-10 shadow-lg">
        <h2 class="text-4xl md:text-6xl font-extrabold mb-4 tracking-tight">Encuentra dónde jugar hoy</h2>
        <p class="text-white/90 mb-8 max-w-2xl mx-auto text-lg md:text-xl font-medium">
          Explora y reserva en las mejores canchas en Trujillo y distritos.
        </p>

        <div class="flex flex-col items-center gap-4 w-full max-w-xl mx-auto mt-6">
          
          <!-- Barra de Búsqueda de Texto -->
          <div class="relative w-full z-10">
            <input 
              id="filtro-texto" 
              type="text" 
              placeholder="Escribe el nombre de la cancha" 
              class="w-full bg-white text-gray-800 rounded-xl px-6 py-3.5 pr-14 outline-none shadow-lg font-medium placeholder-gray-400 focus:ring-4 focus:ring-white/30 transition-all text-base"
            >
            <button 
              id="btn-lupa"
              aria-label="Buscar"
              class="absolute right-2 top-1/2 -translate-y-1/2 p-2 text-sep-green hover:text-[#326955] hover:bg-green-50 rounded-full transition-all duration-200 active:scale-95 focus:outline-none"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6 hover:scale-110 transition-transform duration-200">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
              </svg>
            </button>
          </div>

          <!-- Selectores de Región (Departamento, Provincia, Distrito) -->
          <div class="grid grid-cols-3 w-full gap-2 md:gap-3">
            
            <!-- Departamento (Deshabilitado) -->
            <div class="relative w-full">
              <div class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.684A1.125 1.125 0 0 0 3 6.71v12.083c0 .425.24.815.622 1.006l4.875 2.437a1.125 1.125 0 0 0 1.006 0l5.007-2.504c.316-.159.69-.159 1.006 0Z" />
                </svg>
              </div>
              <select id="filtro-dep" disabled class="w-full bg-gray-200 border border-gray-300/80 text-gray-400 rounded-xl pl-9 pr-2 py-3 outline-none font-medium text-xs cursor-not-allowed appearance-none truncate">
                <option value="la-libertad" selected>La Libertad</option>
              </select>
            </div>

            <!-- Provincia (Deshabilitado) -->
            <div class="relative w-full">
              <div class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                </svg>
              </div>
              <select id="filtro-prov" disabled class="w-full bg-gray-200 border border-gray-300/80 text-gray-400 rounded-xl pl-9 pr-2 py-3 outline-none font-medium text-xs cursor-not-allowed appearance-none truncate">
                <option value="trujillo" selected>Trujillo</option>
              </select>
            </div>

            <!-- Distrito -->
            <div class="relative w-full">
              <div class="absolute left-3 top-1/2 -translate-y-1/2 text-sep-green pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
              </div>
              <select id="filtro-distrito" class="w-full bg-white text-gray-800 border border-gray-200 rounded-xl pl-9 pr-6 py-3 outline-none shadow-md font-medium text-xs cursor-pointer appearance-none truncate">
                <option value="">Distrito (Todos)</option>
                <option value="trujillo">Trujillo Centro</option>
                <option value="la-esperanza">La Esperanza</option>
                <option value="el-porvenir">El Porvenir</option>
                <option value="victor-larco">Víctor Larco Herrera</option>
                <option value="huanchaco">Huanchaco</option>
                <option value="florencia-de-mora">Florencia de Mora</option>
                <option value="laredo">Laredo</option>
                <option value="moche">Moche</option>
                <option value="salaverry">Salaverry</option>
                <option value="poroto">Poroto</option>
                <option value="simbal">Simbal</option>
                <option value="alto-trujillo">Alto Trujillo</option>
              </select>
              <div class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
              </div>
            </div>

          </div>

          <!-- Filtros de Tamaño, Ordenamiento y GPS -->
          <div class="grid grid-cols-3 w-full gap-2 md:gap-3">
            
            <!-- Tamaño/Tipo -->
            <div class="relative w-full">
              <div class="absolute left-3 top-1/2 -translate-y-1/2 text-sep-green pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z" />
                </svg>
              </div>
              <select id="filtro-tipo" class="w-full bg-white text-gray-800 border border-gray-200 rounded-xl pl-9 pr-6 py-3 outline-none shadow-md font-medium text-xs cursor-pointer appearance-none truncate">
                <option value="">Tamaño (Todos)</option>
                <option value="5vs5">Fútbol 5</option>
                <option value="7vs7">Fútbol 7</option>
              </select>
              <div class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
              </div>
            </div>

            <!-- Ordenamiento -->
            <div class="relative w-full">
              <div class="absolute left-3 top-1/2 -translate-y-1/2 text-sep-green pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 7.5 7.5 3m0 0L12 7.5M7.5 3v13.5m13.5 0L16.5 21m0 0L12 16.5m4.5 4.5V7.5" />
                </svg>
              </div>
              <select id="filtro-orden" class="w-full bg-white text-gray-800 border border-gray-200 rounded-xl pl-9 pr-6 py-3 outline-none shadow-md font-medium text-xs cursor-pointer appearance-none truncate">
                <option value="recomendado">Recomendado</option>
                <option value="precio">Más barato</option>
                <option value="distancia" id="opt-distancia" disabled>Distancia (GPS apagado)</option>
              </select>
              <div class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
              </div>
            </div>

            <!-- GPS Button -->
            <button 
              id="btn-gps" 
              type="button"
              class="w-full bg-slate-800 hover:bg-slate-700 active:scale-95 text-white border border-slate-700/50 rounded-xl px-2 py-3 flex items-center justify-center gap-1 font-bold text-xs shadow-md transition-all duration-200 cursor-pointer"
            >
              <span id="gps-status-dot" class="w-2 h-2 bg-slate-500 rounded-full inline-block mr-1"></span>
              <span id="gps-text">Cerca de mí</span>
            </button>

          </div>
        </div>
      </section>

      <section>
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-2xl font-bold text-white tracking-tight">Canchas Populares</h3>
          <span class="text-sm font-semibold text-slate-300 bg-slate-800 px-4 py-1.5 rounded-full border border-slate-700 shadow-inner" id="contador-resultados">
            {localesMock.length} resultados
          </span>
        </div>
        <PitchGrid locales={localesMock} />
      </section>

    </main>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const inputTexto = document.getElementById('filtro-texto') as HTMLInputElement;
        const btnLupa = document.getElementById('btn-lupa') as HTMLButtonElement;
        const selectDistrito = document.getElementById('filtro-distrito') as HTMLSelectElement;
        const selectTipo = document.getElementById('filtro-tipo') as HTMLSelectElement;
        const selectOrden = document.getElementById('filtro-orden') as HTMLSelectElement;
        const btnGps = document.getElementById('btn-gps') as HTMLButtonElement;
        const gpsStatusDot = document.getElementById('gps-status-dot') as HTMLElement;
        const gpsText = document.getElementById('gps-text') as HTMLElement;
        const optDistancia = document.getElementById('opt-distancia') as HTMLOptionElement;
        const grid = document.getElementById('canchas-grid');
        const tarjetas = Array.from(document.querySelectorAll('.cancha-card')) as HTMLElement[];
        const contadorResultados = document.getElementById('contador-resultados');

        let userLat: number | null = null;
        let userLng: number | null = null;
        let gpsActivo = false;

        // Guardamos el índice original para restaurar el orden "Recomendado"
        tarjetas.forEach((tarjeta, index) => {
          tarjeta.setAttribute('data-original-index', index.toString());
        });

        const normalizar = (texto: string) => {
          return texto.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase();
        };

        // Fórmula de Haversine para calcular distancia en km
        const calcularDistancia = (lat1: number, lon1: number, lat2: number, lon2: number) => {
          const R = 6371; // Radio de la Tierra en km
          const dLat = (lat2 - lat1) * Math.PI / 180;
          const dLon = (lon2 - lon1) * Math.PI / 180;
          const a = 
            Math.sin(dLat / 2) * Math.sin(dLat / 2) +
            Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) * 
            Math.sin(dLon / 2) * Math.sin(dLon / 2);
          const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
          return R * c;
        };

        const ordenarTarjetas = (criterio: string) => {
          if (!grid) return;
          
          const tarjetasOrdenadas = Array.from(grid.children) as HTMLElement[];

          tarjetasOrdenadas.sort((a, b) => {
            if (criterio === 'precio') {
              const precioA = parseFloat(a.getAttribute('data-precio') || '0');
              const precioB = parseFloat(b.getAttribute('data-precio') || '0');
              return precioA - precioB;
            } else if (criterio === 'distancia' && gpsActivo && userLat !== null && userLng !== null) {
              const distA = parseFloat(a.getAttribute('data-distancia-val') || '999999');
              const distB = parseFloat(b.getAttribute('data-distancia-val') || '999999');
              return distA - distB;
            } else {
              const originalA = parseInt(a.getAttribute('data-original-index') || '0');
              const originalB = parseInt(b.getAttribute('data-original-index') || '0');
              return originalA - originalB;
            }
          });

          tarjetasOrdenadas.forEach(tarjeta => grid.appendChild(tarjeta));
        };

        const ejecutarFiltro = () => {
          const textoBuscado = normalizar(inputTexto.value);
          const distritoBuscado = selectDistrito.value.toLowerCase();
          const tipoBuscado = selectTipo.value.toLowerCase();
          const criterioOrden = selectOrden.value;
          
          let canchasVisibles = 0;

          tarjetas.forEach((tarjeta) => {
            const nombreTarjeta = normalizar(tarjeta.getAttribute('data-nombre') || '');
            const distritoTarjeta = tarjeta.getAttribute('data-distrito') || '';
            const tiposTarjeta = tarjeta.getAttribute('data-tipo') || '';
            
            const coincideTexto = textoBuscado === '' || nombreTarjeta.includes(textoBuscado);
            const coincideDistrito = distritoBuscado === '' || distritoTarjeta.includes(distritoBuscado);
            const coincideTipo = tipoBuscado === '' || tiposTarjeta.includes(tipoBuscado);
            
            let coincideGPS = true;
            if (gpsActivo && userLat !== null && userLng !== null) {
              const distValStr = tarjeta.getAttribute('data-distancia-val');
              if (distValStr) {
                const distVal = parseFloat(distValStr);
                coincideGPS = distVal <= 5; // Rango de 5km
              } else {
                coincideGPS = false;
              }
            }

            if (coincideTexto && coincideDistrito && coincideTipo && coincideGPS) {
              tarjeta.style.display = 'block';
              canchasVisibles++;
            } else {
              tarjeta.style.display = 'none';
            }
          });

          ordenarTarjetas(criterioOrden);

          if (contadorResultados) {
            contadorResultados.textContent = `${canchasVisibles} resultado${canchasVisibles !== 1 ? 's' : ''}`;
          }
        };

        // Configuración y eventos del GPS
        btnGps.addEventListener('click', () => {
          if (!gpsActivo) {
            // Activar GPS
            gpsText.textContent = "Obteniendo...";
            gpsStatusDot.className = "w-2 h-2 bg-yellow-400 rounded-full inline-block mr-1 animate-ping";

            navigator.geolocation.getCurrentPosition(
              (position) => {
                userLat = position.coords.latitude;
                userLng = position.coords.longitude;
                gpsActivo = true;

                // Actualizar botón
                gpsText.textContent = "Cercano";
                gpsStatusDot.className = "w-2 h-2 bg-yellow-400 rounded-full inline-block mr-1 animate-pulse";
                btnGps.classList.remove('bg-slate-800');
                btnGps.classList.add('bg-red-500', 'border-red-500');

                // Habilitar opción de ordenamiento
                optDistancia.disabled = false;
                optDistancia.textContent = "Más cercano";
                selectOrden.value = "distancia";

                // Calcular distancias y mostrar badges
                tarjetas.forEach(tarjeta => {
                  const lat = parseFloat(tarjeta.getAttribute('data-lat') || '0');
                  const lng = parseFloat(tarjeta.getAttribute('data-lng') || '0');
                  const dist = calcularDistancia(userLat!, userLng!, lat, lng);
                  tarjeta.setAttribute('data-distancia-val', dist.toString());
                  
                  const badge = tarjeta.querySelector('.distancia-badge') as HTMLElement;
                  if (badge) {
                    badge.textContent = `a ${dist.toFixed(1)} km`;
                    badge.classList.remove('hidden');
                  }
                });

                ejecutarFiltro();
              },
              (error) => {
                console.error("Error al obtener ubicación:", error);
                alert("No pudimos acceder a tu ubicación. Por favor, activa los permisos de GPS de tu navegador.");
                
                // Restablecer botón
                gpsText.textContent = "Cerca de mí";
                gpsStatusDot.className = "w-2 h-2 bg-slate-500 rounded-full inline-block mr-1";
                btnGps.className = "w-full bg-slate-800 hover:bg-slate-700 active:scale-95 text-white border border-slate-700/50 rounded-xl px-2 py-3 flex items-center justify-center gap-1 font-bold text-xs shadow-md transition-all duration-200 cursor-pointer";
              },
              { enableHighAccuracy: false, maximumAge: 300000, timeout: 10000 }
            );
          } else {
            // Desactivar GPS
            gpsActivo = false;
            userLat = null;
            userLng = null;

            // Restablecer botón
            gpsText.textContent = "Cerca de mí";
            gpsStatusDot.className = "w-2 h-2 bg-slate-500 rounded-full inline-block mr-1";
            btnGps.className = "w-full bg-slate-800 hover:bg-slate-700 active:scale-95 text-white border border-slate-700/50 rounded-xl px-2 py-3 flex items-center justify-center gap-1 font-bold text-xs shadow-md transition-all duration-200 cursor-pointer";

            // Deshabilitar opción de ordenamiento
            optDistancia.disabled = true;
            optDistancia.textContent = "Distancia (GPS apagado)";
            if (selectOrden.value === 'distancia') {
              selectOrden.value = 'recomendado';
            }

            // Ocultar badges
            tarjetas.forEach(tarjeta => {
              tarjeta.removeAttribute('data-distancia-val');
              const badge = tarjeta.querySelector('.distancia-badge') as HTMLElement;
              if (badge) {
                badge.classList.add('hidden');
              }
            });

            ejecutarFiltro();
          }
        });

        // Eventos generales
        inputTexto.addEventListener('keypress', (e) => {
          if (e.key === 'Enter') {
            ejecutarFiltro();
            inputTexto.blur();
          }
        });

        selectDistrito.addEventListener('change', ejecutarFiltro);
        selectTipo.addEventListener('change', ejecutarFiltro);
        selectOrden.addEventListener('change', ejecutarFiltro);

        if (btnLupa) {
          btnLupa.addEventListener('click', () => {
            ejecutarFiltro();
            inputTexto.blur();
          });
        }
      });
    </script>
  </body>
</html>